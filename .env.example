# ── DATABASE ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/querysafe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=querysafe

# ── REDIS ──────────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme@redis:6379
REDIS_PASSWORD=changeme

# ── AI PROVIDERS (use one) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_PROVIDER=openai

# ── SECURITY ────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=replace-with-32-byte-base64-key

# ── CHROMA ──────────────────────────────────────────────────────────────
CHROMA_URL=http://chroma:8001

# ── FRONTEND ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api

# ── ENVIRONMENT ─────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
# ============================================================
# QuerySafe — Environment Variables Example
# Copy this to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# ── Database (PostgreSQL metadata DB) ───────────────────────
DATABASE_URL=postgresql://postgres:querysafe_pass@postgres:5432/querysafe
POSTGRES_PASSWORD=querysafe_pass

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://:redis_pass@redis:6379
REDIS_PASSWORD=redis_pass

# ── AI Provider ─────────────────────────────────────────────
# Choose: "anthropic" or "openai"
AI_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI (GPT-4)
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4-turbo

# ── Vector Store (ChromaDB) ──────────────────────────────────
CHROMA_URL=http://chroma:8001

# ── Security & Auth ──────────────────────────────────────────
# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET

# AES-256 encryption key for DB credentials — must be exactly 32 bytes
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_KEY_HERE_!!!

# ── Backend internal service URLs ────────────────────────────
SECURITY_SERVICE_URL=http://backend:8000
DATABASE_SERVICE_URL=http://backend:8000

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api

# ── Email (for OTP notifications) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@querysafe.io

# ── Feature Flags ─────────────────────────────────────────────
# Set to "true" to enable zero-retention mode (sessions auto-deleted)
ZERO_RETENTION_MODE=false

# Max rows returned per query (security enforcement)
MAX_QUERY_ROWS=500

# Query timeout in seconds
QUERY_TIMEOUT_SECONDS=10

# ============================================================
# QuerySafe environment variables
# Copy this file to .env and fill in the secrets/values below.
# ============================================================

# ------------------------------------------------------------------
# Database service secrets used by docker-compose.yml
# ------------------------------------------------------------------

# Postgres superuser password for the local compose stack.
POSTGRES_PASSWORD=change-me-postgres-password

# Redis password used by the Redis container and the backend connection URL.
REDIS_PASSWORD=change-me-redis-password

# ------------------------------------------------------------------
# AI provider configuration
# ------------------------------------------------------------------

# Active LLM provider: anthropic or openai.
AI_PROVIDER=anthropic

# OpenAI settings used only when AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

# Anthropic settings used only when AI_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# ------------------------------------------------------------------
# Service URLs used by the backend at runtime
# ------------------------------------------------------------------

# ChromaDB HTTP endpoint inside the compose network.
CHROMA_URL=http://chroma:8001

# Redis connection string used by backend/AI memory helpers.
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# Internal service URLs used by the AI routes.
DATABASE_SERVICE_URL=http://backend:8000
SECURITY_SERVICE_URL=http://backend:8000

# Allowed browser origins for CORS.
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# ------------------------------------------------------------------
# Frontend runtime configuration
# ------------------------------------------------------------------

# Browser-facing API base path when the app is served behind nginx.
NEXT_PUBLIC_API_BASE_URL=/api

# ------------------------------------------------------------------
# Optional local overrides
# ------------------------------------------------------------------

# Set to a different host if you are exposing services outside Docker.
# CHROMA_URL=http://localhost:8001
# REDIS_URL=redis://:change-me-redis-password@localhost:6379/0